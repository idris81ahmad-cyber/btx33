# BIYORA SHOP Environment Variables
# Copy to .env.local and fill in real values.

# NextAuth (CRITICAL - required for admin + customer accounts)
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon Postgres via Vercel Marketplace (orders, users, products, reviews)
# Install: vercel integration add neon
# Pull locally: vercel env pull .env.local
DATABASE_URL=
POSTGRES_URL=
# After connecting Neon, run: npm run db:setup

# Resend email (order confirmations, contact replies)
RESEND_API_KEY=
RESEND_FROM_EMAIL=BIYORA SHOP <hello@biyorashop.com>
CONTACT_INBOX_EMAIL=hello@biyorashop.com

# Product storage
BLOB_READ_WRITE_TOKEN=
GITHUB_TOKEN=

# Paystack Payment Integration (HIGH PRIORITY)
# Get your keys from https://dashboard.paystack.com
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_replace_with_your_key
PAYSTACK_SECRET_KEY=sk_test_replace_with_your_key

# Paystack webhook URL (configure in Paystack dashboard):
# https://biyora-shop.vercel.app/api/paystack/webhook
# Signature verification uses PAYSTACK_SECRET_KEY (HMAC SHA512)