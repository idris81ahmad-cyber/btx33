# BIYORA SHOP Environment Variables
# Copy to .env.local and fill in real values.

# NextAuth (required for admin + customer accounts)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-strong-secret-here

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Postgres (orders, users, reviews — optional but recommended)
POSTGRES_URL=

# Resend email (order confirmations, contact replies)
RESEND_API_KEY=
RESEND_FROM_EMAIL=BIYORA SHOP <hello@biyorashop.com>
CONTACT_INBOX_EMAIL=hello@biyorashop.com

# Product storage (set at least one on Vercel)
BLOB_READ_WRITE_TOKEN=
GITHUB_TOKEN=