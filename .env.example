# =============================================================================
# BIYORA SHOP — Environment Variables
# Copy to .env.local and fill real values. Never commit .env.local.
# Production: set these in Vercel → Project → Settings → Environment Variables
# =============================================================================

# --- CRITICAL (app will not work correctly without these) ---------------------

# NextAuth — generate: node scripts/generate-secret.mjs
NEXTAUTH_SECRET=
# Public origin used by NextAuth callbacks
NEXTAUTH_URL=http://localhost:3000

# Canonical public site URL (Paystack callback_url uses this)
# Production MUST be: https://biyora-shop.vercel.app  (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon / Vercel Postgres (orders, users, products, reviews)
# After connecting Neon: npm run db:setup
DATABASE_URL=
POSTGRES_URL=
# Optional Neon variants (auto-mapped if POSTGRES_URL empty):
# DATABASE_URL_UNPOOLED=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_PRISMA_URL=

# Paystack — https://dashboard.paystack.com
# Keep public + secret in the SAME mode (both test OR both live)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_replace_with_your_key
PAYSTACK_SECRET_KEY=sk_test_replace_with_your_key
#
# Webhook URL (Paystack Dashboard → Settings → API Keys & Webhooks):
#   https://biyora-shop.vercel.app/api/paystack/webhook
#   (alias also works) https://biyora-shop.vercel.app/api/webhooks/paystack
#   or https://btx33.vercel.app/api/paystack/webhook if that is your live host
# Signature: HMAC SHA512 of raw body with PAYSTACK_SECRET_KEY
# Health check (GET): same URL as webhook

# --- HIGH VALUE (recommended for production) ----------------------------------

# Bootstrap / rotate admin (never commit real passwords)
# Used by npm run db:setup seed and scripts/set-admin-password.mjs
# ADMIN_EMAIL=you@yourdomain.com
# ADMIN_PASSWORD=use-a-long-random-secret-12+
# ADMIN_NAME=BIYORA Admin
# ADMIN_FORCE_PASSWORD=1   # only when intentionally rotating via seed

# Resend — order confirmations + contact form
# https://resend.com — verify a sending domain for production
RESEND_API_KEY=
RESEND_FROM_EMAIL=BIYORA SHOP <hello@biyorashop.com>
CONTACT_INBOX_EMAIL=hello@biyorashop.com

# Vercel Blob — admin product image uploads
BLOB_READ_WRITE_TOKEN=

# Optional fixed shipping fee in NGN (default 2500)
# SHIPPING_FEE_NGN=2500

# --- OPTIONAL -----------------------------------------------------------------

# GitHub product JSON fallback (legacy; prefer Postgres)
GITHUB_TOKEN=

# Sentry error monitoring (optional)
# Create a Next.js project at https://sentry.io and paste the DSN
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENABLE_DEV=1

# PWA: register service worker on localhost (default off)
# NEXT_PUBLIC_PWA_DEV=1

# =============================================================================
# Local checklist
# 1. cp .env.example .env.local
# 2. vercel env pull .env.local   (optional, pulls Neon + secrets)
# 3. npm run db:setup
# 4. npm run dev
# 5. GET /api/health  → check flags.ok
# =============================================================================
