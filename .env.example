# BTX3 Environment Variables
# Copy this to .env.local and fill in real values.

# Required for NextAuth (auth is used for Admin panel)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-here-generate-with-openssl-rand-base64-32

# Optional: Vercel Blob for production image uploads in Admin
# BLOB_READ_WRITE_TOKEN=

# Site URL (for future use)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
