# BIYORA SHOP Environment Variables
# Copy to .env.local and fill in real values.

# NextAuth (CRITICAL - required for admin + customer accounts)
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Postgres (orders, users, reviews — optional but recommended)
POSTGRES_URL=

# Resend email (order confirmations, contact replies)
RESEND_API_KEY=
RESEND_FROM_EMAIL=BIYORA SHOP <hello@biyorashop.com>
CONTACT_INBOX_EMAIL=hello@biyorashop.com

# Product storage (set at least one on Vercel)
BLOB_READ_WRITE_TOKEN=
GITHUB_TOKEN=

# Paystack Payment Integration (HIGH PRIORITY for live checkout)
# Get keys from https://dashboard.paystack.com
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Paystack Webhook Secret (for verifying payment events in production)
# Set this in Vercel env vars + configure webhook URL in Paystack dashboard
PAYSTACK_WEBHOOK_SECRET=